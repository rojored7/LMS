# Test environment configuration
NODE_ENV=test
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Database - Use a test database
DATABASE_URL=postgresql://postgres:password@localhost:5432/plataforma_cursos_test?schema=public

# Redis
REDIS_URL=redis://localhost:6379/1
REDIS_TTL=3600

# JWT
JWT_SECRET=test-jwt-secret-key-for-testing-purposes-only-32chars
JWT_REFRESH_SECRET=test-jwt-refresh-secret-key-for-testing-purposes
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Email (mock for tests)
EMAIL_HOST=smtp.test.com
EMAIL_PORT=587
EMAIL_USER=test@test.com
EMAIL_PASSWORD=testpassword
EMAIL_FROM=noreply@test.com
