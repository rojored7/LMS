# ============================================
# CIBER PLATFORM - Variables de Entorno
# Copiar como .env (dev) / .env.qa / .env.prod
# ============================================

# ===== GENERAL =====
APP_ENV=development
NODE_ENV=development

# ===== BASE DE DATOS POSTGRESQL =====
DB_NAME=ciber_platform
DB_USER=ciber_admin
DB_PASSWORD=CHANGE-ME-use-strong-random-password
DB_PORT=5433

# ===== REDIS =====
REDIS_PASSWORD=CHANGE-ME-redis-password
REDIS_PORT=6380

# ===== BACKEND API =====
BACKEND_PORT=4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost"]

# JWT (minimo 32 chars - generar: openssl rand -hex 32)
JWT_SECRET=CHANGE-ME-minimum-32-characters-long-random-string
JWT_REFRESH_SECRET=CHANGE-ME-minimum-32-characters-long-random-refresh
JWT_EXPIRES_IN_MINUTES=15
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Rate limiting
RATE_LIMIT_GLOBAL=500/15minutes

# Pool de conexiones
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ===== FRONTEND =====
FRONTEND_PORT=3000

# ===== CODE EXECUTOR =====
EXECUTOR_PORT=5000
SANDBOX_TIMEOUT=30000
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=1
SANDBOX_NETWORK_DISABLED=true
# Generar: openssl rand -hex 16
EXECUTOR_SECRET=CHANGE-ME-minimum-16-characters-executor
# Sandboxes concurrentes: 2 en dev, 4 en qa/prod
MAX_CONCURRENT_SANDBOXES=2

# ===== NGINX =====
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ===== EMAIL SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=capacitaciones@itac.co

# ===== CERTIFICADOS (solo PROD) =====
# Copiar los archivos .crt y .key en /etc/ssl/itac/ del servidor prod
# sudo cp capacitaciones.itac.co.crt /etc/ssl/itac/
# sudo cp capacitaciones.itac.co.key /etc/ssl/itac/

# ===== SEED INICIAL =====
ADMIN_SEED_EMAIL=admin@itac.co
ADMIN_SEED_PASSWORD=CHANGE-ME-minimum-32-characters

# ===== CERTIFICADOS DE CURSO =====
CERTIFICATE_BASE_URL=http://localhost:4000/certificates

# ===== ERROR TRACKING (opcional) =====
GLITCHTIP_DSN=
LOG_LEVEL=info
