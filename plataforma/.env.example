# ===== CONFIGURACIÓN DE ENTORNO =====
# Copiar este archivo a .env y ajustar los valores

# ===== GENERAL =====
APP_ENV=development
NODE_ENV=development
# NODE_ENV=production

# ===== BASE DE DATOS POSTGRESQL =====
DB_NAME=ciber_platform
DB_USER=ciber_admin
DB_PASSWORD=CHANGE-ME-use-strong-random-password
DB_PORT=5432

# ===== REDIS =====
REDIS_PASSWORD=redispass123
REDIS_PORT=6379

# ===== BACKEND API =====
BACKEND_PORT=4000
JWT_SECRET=CHANGE-ME-minimum-32-characters-long-random-string
JWT_REFRESH_SECRET=CHANGE-ME-minimum-32-characters-long-random-refresh
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000,http://localhost

# ===== FRONTEND =====
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost/api
REACT_APP_EXECUTOR_URL=http://localhost/executor
REACT_APP_ENV=development

# ===== CODE EXECUTOR =====
EXECUTOR_PORT=5000
SANDBOX_TIMEOUT=30000
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=1
SANDBOX_NETWORK_DISABLED=true
EXECUTOR_SECRET=CHANGE-ME-minimum-16-characters-executor

# ===== NGINX =====
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ===== EMAIL (para recuperación de contraseña y certificados) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@ciberplatform.com

# ===== STORAGE (para proyectos subidos) =====
# AWS S3 (opcional, por defecto usa volúmenes locales)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=ciber-platform-uploads

# ===== MONITORING (opcional) =====
# SENTRY_DSN=
# LOG_LEVEL=info
