# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql://ciber_admin:changeme@postgres:5432/ciber_platform
REDIS_URL=redis://redis:6379/0
REDIS_TTL=3600

# JWT - MUST be 32+ chars, MUST NOT contain known weak values
JWT_SECRET=CHANGE-ME-generate-a-random-64-char-string-here-now
JWT_REFRESH_SECRET=CHANGE-ME-generate-another-random-64-char-string

# JWT Expiry
JWT_EXPIRES_IN_MINUTES=15
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_GLOBAL=200/15minutes
RATE_LIMIT_AUTH_LOGIN=10/15minutes
RATE_LIMIT_AUTH_REGISTER=5/hour
RATE_LIMIT_AUTH_RESET=3/hour

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Code Executor
EXECUTOR_SERVICE_URL=http://executor:5000
EXECUTOR_TIMEOUT=30
EXECUTOR_SECRET=CHANGE-ME-shared-secret-with-executor

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Certificates
CERTIFICATE_STORAGE_PATH=./certificates
CERTIFICATE_BASE_URL=http://localhost:4000/certificates

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
