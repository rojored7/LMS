# ============================================================================
# CONFIGURACIÓN DE ENTORNO - PLATAFORMA MULTI-CURSO DE CIBERSEGURIDAD
# ============================================================================
# Este archivo contiene todas las variables de entorno necesarias para ejecutar
# la aplicación. Copia este archivo a .env y configura los valores apropiados.
# IMPORTANTE: NUNCA commitees el archivo .env al repositorio

# ============================================================================
# ENTORNO
# ============================================================================
# Entorno de ejecución: development | production | test
NODE_ENV=development

# ============================================================================
# SERVIDOR
# ============================================================================
# Puerto en el que el servidor escuchará
PORT=5000

# Host del servidor (0.0.0.0 para permitir conexiones externas)
HOST=0.0.0.0

# URL del frontend (para configurar CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# BASE DE DATOS - PostgreSQL
# ============================================================================
# URL de conexión a PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Ejemplo: postgresql://postgres:password@localhost:5432/plataforma_cursos?schema=public
DATABASE_URL=postgresql://postgres:password@localhost:5432/plataforma_cursos?schema=public

# ============================================================================
# REDIS
# ============================================================================
# URL de conexión a Redis
# Formato: redis://[:password@]host:port[/db-number]
# Ejemplo: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# TTL por defecto para caché en segundos (3600 = 1 hora)
REDIS_TTL=3600

# ============================================================================
# AUTENTICACIÓN JWT
# ============================================================================
# Secreto para firmar tokens JWT (mínimo 32 caracteres)
# IMPORTANTE: Genera uno fuerte y único para producción
# Puedes usar: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-chars

# Secreto para firmar refresh tokens JWT (mínimo 32 caracteres)
# IMPORTANTE: Debe ser diferente al JWT_SECRET
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production-min-32

# Tiempo de expiración del access token (formato: 15m, 1h, 7d)
JWT_EXPIRES_IN=15m

# Tiempo de expiración del refresh token (formato: 15m, 1h, 7d)
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# ENCRIPTACIÓN DE CONTRASEÑAS
# ============================================================================
# Número de rounds para bcrypt (10-15 recomendado, mayor = más seguro pero más lento)
BCRYPT_ROUNDS=12

# ============================================================================
# RATE LIMITING
# ============================================================================
# Ventana de tiempo para rate limiting en milisegundos (900000 = 15 minutos)
RATE_LIMIT_WINDOW_MS=900000

# Máximo número de requests permitidos por ventana de tiempo
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# SUBIDA DE ARCHIVOS
# ============================================================================
# Tamaño máximo de archivo en bytes (10485760 = 10MB)
MAX_FILE_SIZE=10485760

# Directorio para almacenar archivos subidos
UPLOAD_DIR=./uploads

# ============================================================================
# CODE EXECUTOR SERVICE
# ============================================================================
# URL del servicio de ejecución de código (sandbox)
EXECUTOR_SERVICE_URL=http://localhost:6000

# Timeout para ejecución de código en milisegundos (30000 = 30 segundos)
EXECUTOR_TIMEOUT=30000

# ============================================================================
# EMAIL (SMTP)
# ============================================================================
# Host del servidor SMTP
SMTP_HOST=smtp.gmail.com

# Puerto SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Usuario SMTP (email)
SMTP_USER=your-email@gmail.com

# Contraseña SMTP (para Gmail usar App Password)
SMTP_PASS=your-app-password

# Dirección de email remitente
SMTP_FROM=noreply@plataforma-cursos.com

# ============================================================================
# CERTIFICADOS
# ============================================================================
# Ruta donde se almacenarán los certificados generados
CERTIFICATE_STORAGE_PATH=./certificates

# URL base para acceder a los certificados
CERTIFICATE_BASE_URL=http://localhost:5000/certificates

# ============================================================================
# LOGGING
# ============================================================================
# Nivel de logging: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info

# Directorio donde se almacenarán los logs
LOG_DIR=./logs

# Activar logging en archivos (true/false)
# En producción se activa automáticamente
LOG_TO_FILE=false

# ============================================================================
# MONITOREO Y ERROR TRACKING (OPCIONAL)
# ============================================================================
# Sentry DSN para tracking de errores (opcional)
# Obtén tu DSN en https://sentry.io
SENTRY_DSN=

# ============================================================================
# API KEYS (OPCIONAL)
# ============================================================================
# Nombre del header para API keys
API_KEY_HEADER=X-API-Key

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
# 1. NUNCA commitees el archivo .env al repositorio
# 2. Agrega .env al .gitignore
# 3. En producción, usa variables de entorno reales en lugar de un archivo .env
# 4. Cambia todos los secretos y contraseñas por valores seguros
# 5. Usa herramientas como dotenv-vault o AWS Secrets Manager para gestionar secretos
# 6. Genera JWT secrets con: openssl rand -base64 32
# 7. Para Gmail, usa App Passwords: https://support.google.com/accounts/answer/185833
