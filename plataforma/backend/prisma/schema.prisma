// Prisma Schema - Plataforma Multi-Curso de Ciberseguridad
// Versión: 1.0
// Generador: TypeScript client para Prisma ORM

generator client {
  provider        = "prisma-client-js"
  // Genera tipos TypeScript optimizados
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USUARIOS Y AUTENTICACIÓN
// ============================================================================

enum UserRole {
  ADMIN // Administrador completo del sistema
  INSTRUCTOR // Creador y gestor de contenido educativo
  STUDENT // Usuario final que consume cursos
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatar       String? // URL del avatar del usuario
  role         UserRole @default(STUDENT)
  xp           Int      @default(0) // Puntos de experiencia para gamificación
  theme        String   @default("system") // system, light, dark
  locale       String   @default("es") // es, en

  // Relación con perfil de entrenamiento
  trainingProfileId String?
  trainingProfile   TrainingProfile? @relation(fields: [trainingProfileId], references: [id])

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relaciones
  enrollments         Enrollment[]
  quizAttempts        QuizAttempt[]
  labSubmissions      LabSubmission[]
  projectSubmissions  ProjectSubmission[]
  reviewedProjects    ProjectSubmission[]  @relation("ReviewedProjects")
  userProgress        UserProgress[]
  userLessonProgress  UserLessonProgress[] @relation("UserLessonProgress")
  certificates        Certificate[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  badges              UserBadge[]
  notifications       Notification[]
  sentMessages        ChatMessage[]       @relation("SentMessages")
  receivedMessages    ChatMessage[]       @relation("ReceivedMessages")

  // Índices para búsquedas frecuentes
  @@index([email])
  @@index([role])
  @@index([trainingProfileId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token, expiresAt])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ============================================================================
// PERFILES DE ENTRENAMIENTO
// ============================================================================

model TrainingProfile {
  id          String   @id @default(cuid())
  name        String   @unique // Ej: "SOC Analyst", "Pentester", "Incident Response"
  slug        String   @unique // URL-friendly: "soc-analyst", "pentester"
  description String
  icon        String? // Nombre del icono o emoji
  color       String? // Código hexadecimal para theming
  createdAt   DateTime @default(now())

  // Relaciones
  users          User[]
  courseProfiles CourseProfile[]

  @@index([slug])
  @@map("training_profiles")
}

// ============================================================================
// CURSOS
// ============================================================================

enum CourseLevel {
  BEGINNER // Principiante
  INTERMEDIATE // Intermedio
  ADVANCED // Avanzado
  EXPERT // Experto
}

model Course {
  id          String      @id @default(cuid())
  slug        String      @unique // URL-friendly identifier
  title       String
  description String      @db.Text
  thumbnail   String? // URL de imagen de portada
  duration    Int // Duración estimada en minutos
  level       CourseLevel
  tags        String[] // Array de tags para categorización
  isPublished Boolean     @default(false)
  author      String // Nombre del autor/instructor
  version     String      @default("1.0")
  price       Float       @default(0) // Precio del curso (0 = gratuito)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  modules        Module[]
  courseProfiles CourseProfile[]
  enrollments    Enrollment[]
  projects       Project[]
  certificates   Certificate[]
  scormPackages  ScormPackage[]

  @@index([slug])
  @@index([isPublished])
  @@index([level])
  @@map("courses")
}

// Tabla pivot: Relación muchos-a-muchos entre Course y TrainingProfile
model CourseProfile {
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  profileId String
  profile   TrainingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  required Boolean @default(false) // ¿Es obligatorio para este perfil?
  order    Int     @default(0) // Orden recomendado en el perfil

  @@id([courseId, profileId])
  @@index([profileId])
  @@map("course_profiles")
}

// ============================================================================
// MÓDULOS
// ============================================================================

model Module {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  order       Int // Orden del módulo dentro del curso
  title       String
  description String  @db.Text
  duration    Int // Duración estimada en minutos
  isPublished Boolean @default(false)

  // Relaciones
  lessons      Lesson[]
  quizzes      Quiz[]
  labs         Lab[]
  userProgress UserProgress[]

  @@unique([courseId, order])
  @@index([courseId])
  @@map("modules")
}

// ============================================================================
// LECCIONES
// ============================================================================

enum LessonType {
  TEXT // Contenido de texto/markdown
  VIDEO // Video embebido
  INTERACTIVE // Contenido interactivo
  READING // Material de lectura externa
}

model Lesson {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  order         Int // Orden dentro del módulo
  title         String
  content       String     @db.Text // Markdown o HTML
  type          LessonType @default(TEXT)
  estimatedTime Int // Tiempo estimado en minutos

  // Relaciones
  userProgress       UserProgress[]
  userLessonProgress UserLessonProgress[]

  @@unique([moduleId, order])
  @@index([moduleId])
  @@map("lessons")
}

// ============================================================================
// QUIZZES Y EVALUACIONES
// ============================================================================

enum QuestionType {
  MULTIPLE_CHOICE // Una sola respuesta correcta
  MULTIPLE_SELECT // Múltiples respuestas correctas
  TRUE_FALSE // Verdadero o Falso
  SHORT_ANSWER // Respuesta corta de texto
}

model Quiz {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title        String
  description  String @db.Text
  passingScore Int // Puntuación mínima para aprobar (%)
  timeLimit    Int? // Límite de tiempo en minutos (null = sin límite)
  attempts     Int    @default(3) // Número máximo de intentos permitidos

  // Relaciones
  questions    Question[]
  quizAttempts QuizAttempt[]

  @@index([moduleId])
  @@map("quizzes")
}

model Question {
  id     String @id @default(cuid())
  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  order         Int // Orden de la pregunta en el quiz
  type          QuestionType
  question      String       @db.Text
  options       Json? // Array de opciones para multiple choice/select
  correctAnswer Json // Respuesta(s) correcta(s)
  explanation   String?      @db.Text // Explicación de la respuesta correcta

  @@unique([quizId, order])
  @@index([quizId])
  @@map("questions")
}

model QuizAttempt {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  quizId String
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  answers Json // Object con las respuestas del usuario
  score   Int // Puntuación obtenida (%)
  passed  Boolean // ¿Aprobó el quiz?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([quizId])
  @@index([userId, quizId])
  @@map("quiz_attempts")
}

// ============================================================================
// LABORATORIOS PRÁCTICOS
// ============================================================================

model Lab {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title       String
  description String @db.Text
  language    String // Lenguaje de programación: "python", "javascript", "bash"
  starterCode String @db.Text // Código inicial proporcionado
  solution    String @db.Text // Solución de referencia (solo visible para instructores)
  tests       Json // Test cases para validar la solución
  hints       Json? // Array de pistas opcionales

  // Relaciones
  submissions LabSubmission[]

  @@index([moduleId])
  @@map("labs")
}

model LabSubmission {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  labId String
  lab   Lab    @relation(fields: [labId], references: [id], onDelete: Cascade)

  code     String @db.Text // Código enviado por el estudiante
  language String // python, javascript, bash

  stdout        String? @db.Text // Output estándar
  stderr        String? @db.Text // Error output
  exitCode      Int? // Código de salida
  executionTime Int? // Tiempo de ejecución en ms

  passed   Boolean @default(false) // ¿Pasó todos los tests?
  feedback String? @db.Text // Feedback automático
  attempts Int     @default(1) // Número de intentos

  submittedAt DateTime @default(now())

  @@index([userId])
  @@index([labId])
  @@index([userId, labId])
  @@map("lab_submissions")
}

// ============================================================================
// PROYECTOS FINALES
// ============================================================================

enum ProjectStatus {
  PENDING // Enviado, esperando revisión
  REVIEWING // En proceso de revisión
  APPROVED // Aprobado
  REJECTED // Rechazado, requiere cambios
}

model Project {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title        String
  description  String    @db.Text
  requirements Json // Requisitos del proyecto
  rubric       Json // Rúbrica de evaluación
  dueDate      DateTime?

  // Relaciones
  submissions ProjectSubmission[]

  @@index([courseId])
  @@map("projects")
}

model ProjectSubmission {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  repositoryUrl String? // URL del repositorio (GitHub, GitLab)
  files         Json? // Metadata de archivos subidos { name, url, size }[]
  description   String? @db.Text // Descripción del proyecto

  status   ProjectStatus @default(PENDING)
  score    Int? // Calificación (0-100)
  feedback String?       @db.Text // Feedback del instructor

  reviewedBy String? // ID del instructor que revisó
  reviewer   User?     @relation("ReviewedProjects", fields: [reviewedBy], references: [id])
  reviewedAt DateTime? // Fecha de revisión

  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@map("project_submissions")
}

// ============================================================================
// INSCRIPCIONES Y PROGRESO
// ============================================================================

model Enrollment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  progress          Int       @default(0) // Porcentaje de progreso (0-100)
  progressPercentage Int?     // Porcentaje alternativo de progreso
  lastAccessedAt    DateTime? // Última vez que accedió al curso
  enrolledAt        DateTime  @default(now())
  completedAt       DateTime? // Fecha de finalización del curso
  certificate       String?   // ID del certificado emitido

  // Relaciones
  userProgress UserProgress[]

  @@unique([userId, courseId]) // Un usuario no puede inscribirse dos veces al mismo curso
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model UserProgress {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  enrollmentId String?
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  lessonId String?
  lesson   Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  status      String   @default("pending") // pending, in_progress, completed
  completed   Boolean  @default(false)
  progress    Int      @default(0) // Porcentaje de progreso (0-100)
  score       Int?     // Puntuación si es evaluable
  timeSpent   Int      @default(0) // Tiempo en minutos
  lastAccess  DateTime @default(now())
  completedAt DateTime?

  @@unique([userId, moduleId, lessonId])
  @@index([userId])
  @@index([moduleId])
  @@map("user_progress")
}

// ============================================================================
// CERTIFICADOS
// ============================================================================

model Certificate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  issuedAt         DateTime @default(now())
  certificateUrl   String // URL del PDF del certificado
  verificationCode String   @unique // Código único para verificar autenticidad
  emailSent        Boolean  @default(false) // Flag para tracking de email enviado

  @@unique([userId, courseId]) // Un usuario solo puede tener un certificado por curso
  @@index([userId])
  @@index([courseId])
  @@index([verificationCode])
  @@map("certificates")
}

// ============================================================================
// BADGES Y GAMIFICACIÓN
// ============================================================================

model Badge {
  id          String   @id @default(cuid())
  name        String   @unique // Ej: "Módulo 1 Completado", "Quiz Master"
  slug        String   @unique // URL-friendly: "modulo-1-completado"
  description String   @db.Text
  icon        String? // URL o nombre del icono
  color       String? // Color hexadecimal para UI
  xpReward    Int      @default(0) // XP otorgado al conseguir el badge
  createdAt   DateTime @default(now())

  // Relaciones
  userBadges UserBadge[]

  @@index([slug])
  @@map("badges")
}

model UserBadge {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  badgeId String
  badge   Badge  @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  awardedAt DateTime @default(now())

  @@unique([userId, badgeId]) // Un usuario no puede recibir el mismo badge dos veces
  @@index([userId])
  @@index([badgeId])
  @@map("user_badges")
}

// ============================================================================
// NOTIFICACIONES
// ============================================================================

enum NotificationType {
  BADGE_AWARDED // Badge obtenido
  COURSE_COMPLETED // Curso completado
  CERTIFICATE_ISSUED // Certificado emitido
  QUIZ_PASSED // Quiz aprobado
  LAB_PASSED // Lab completado
  PROJECT_GRADED // Proyecto calificado
  COURSE_ASSIGNED // Curso asignado por admin
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    NotificationType
  title   String
  message String           @db.Text
  read    Boolean          @default(false)
  data    Json? // Datos adicionales relacionados (courseId, badgeId, etc)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@map("notifications")
}

// ============================================================================
// TRADUCCIONES Y LOCALIZACIÓN
// ============================================================================

model Translation {
  id        String   @id @default(cuid())
  key       String
  locale    String   @default("es")
  value     String   @db.Text
  context   String?  // Contexto para traducción (ej: "navigation", "course", "quiz")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale])
  @@index([key])
  @@map("translations")
}

// ============================================================================
// CHAT Y MENSAJERÍA
// ============================================================================

model ChatMessage {
  id          String   @id @default(cuid())
  roomId      String   // ID del chat room (puede ser courseId, supportId, etc)
  senderId    String
  sender      User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  recipientId String?  // Opcional para mensajes broadcast
  recipient   User?    @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)
  message     String   @db.Text
  type        String   @default("text") // text, file, image, code
  metadata    Json?    // Información adicional (archivo URL, tipo de código, etc)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([senderId])
  @@index([recipientId])
  @@map("chat_messages")
}

// ============================================================================
// PAQUETES SCORM
// ============================================================================

model ScormPackage {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  version     String   // Versión de SCORM (1.2, 2004)
  manifest    Json     // Estructura del manifest.xml
  files       Json     // Lista de archivos del paquete
  uploadedAt  DateTime @default(now())
  uploadedBy  String?  // ID del usuario que subió el paquete

  @@index([courseId])
  @@map("scorm_packages")
}

// ============================================================================
// PROGRESO DETALLADO DE LECCIONES
// ============================================================================

model UserLessonProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserLessonProgress", fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  completed   Boolean  @default(false)
  progress    Int      @default(0) // Porcentaje de la lección completada
  timeSpent   Int      @default(0) // Tiempo en minutos
  score       Int?     // Puntuación si la lección tiene evaluación
  lastAccess  DateTime @default(now())
  completedAt DateTime?

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@map("user_lesson_progress")
}

// ============================================================================
// AUDIT LOG - TRACKING DE CAMBIOS
// ============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   // Usuario que realizó la acción
  action     String   // COURSE_CREATED, COURSE_UPDATED, etc.
  entityType String   // Course, Module, Lesson, Quiz, Lab
  entityId   String   // ID de la entidad afectada
  metadata   Json?    // Información adicional del contexto
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
