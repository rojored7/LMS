# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ===========================================

# ===== GENERAL =====
NODE_ENV=production
COMPOSE_PROJECT_NAME=ciber-platform-prod

# ===== DATABASE =====
DB_NAME=ciber_platform
DB_USER=ciber_admin
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_PORT=5433
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# ===== REDIS =====
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
REDIS_PORT=6380
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379

# ===== JWT SECRETS (MINIMUM 32 CHARACTERS) =====
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ===== BACKEND =====
BACKEND_PORT=4000

# ===== FRONTEND =====
FRONTEND_PORT=3000
FRONTEND_URL=https://your-domain.com
VITE_API_URL=https://your-domain.com/api
VITE_EXECUTOR_URL=https://your-domain.com/executor

# ===== EXECUTOR =====
EXECUTOR_PORT=5000
SANDBOX_TIMEOUT=30000
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_LIMIT=1
SANDBOX_NETWORK_DISABLED=true

# ===== CORS =====
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# ===== NGINX =====
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ===== EMAIL (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@your-domain.com

# ===== BACKUPS =====
BACKUP_DIR=./database/backups
KEEP_BACKUPS=7
BACKUP_BEFORE_DEPLOY=true
